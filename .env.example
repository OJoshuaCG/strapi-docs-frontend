# URL base de la API de Strapi (sin slash final)
STRAPI_URL=https://strapi-admin.docs.cero208.mx

# Slug del documentation-space a renderizar
DOCUMENTATION_SPACE_SLUG=omnicanal

# Token de API (Read-only) para acceder a borradores / Live Preview
# Dejar vacío si solo se necesita contenido publicado
STRAPI_API_TOKEN=

# Locales soportados separados por coma (en el mismo orden en que aparecerán en el selector)
SUPPORTED_LOCALES=es,en

# Locale por defecto (debe estar en SUPPORTED_LOCALES)
DEFAULT_LOCALE=es
