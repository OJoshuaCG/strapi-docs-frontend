---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Sidebar from '@/components/layout/Sidebar.astro';
import TableOfContents from '@/components/layout/TableOfContents.astro';
import Footer from '@/components/layout/Footer.astro';
import type {
  DocumentationSpaceSetting,
  DocumentationSection,
  SidebarCategory,
  TocEntry,
} from '@/lib/domain/types';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  settings: DocumentationSpaceSetting | null;
  sections: DocumentationSection[];
  sidebarCategories: SidebarCategory[];
  activeSectionSlug?: string;
  activeCategorySlug?: string;
  activeArticleSlug?: string;
  toc?: TocEntry[];
  locale: string;
  supportedLocales: string[];
}

const {
  title,
  description,
  ogImage,
  canonicalUrl,
  settings,
  sections,
  sidebarCategories,
  activeSectionSlug,
  activeCategorySlug,
  activeArticleSlug,
  toc = [],
  locale,
  supportedLocales,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  settings={settings}
  locale={locale}
>
  <div class="flex flex-col min-h-screen" style="background-color: var(--bg-primary);">
    <Header
      settings={settings}
      sections={sections}
      activeSectionSlug={activeSectionSlug}
      locale={locale}
      supportedLocales={supportedLocales}
    />

    <div
      class="flex flex-1"
      style={`padding-top: var(--header-height, 3.5rem);`}
    >
      <!-- Sidebar -->
      <aside
        id="sidebar"
        class="fixed left-0 top-0 h-full overflow-y-auto hidden lg:block z-30 border-r"
        style="
          width: var(--sidebar-width, 16rem);
          padding-top: var(--header-height, 3.5rem);
          background-color: var(--bg-sidebar);
          border-color: var(--border-color);
        "
      >
        <Sidebar
          categories={sidebarCategories}
          activeCategorySlug={activeCategorySlug}
          activeArticleSlug={activeArticleSlug}
          locale={locale}
        />
      </aside>

      <!-- Mobile sidebar overlay -->
      <div
        id="sidebar-overlay"
        class="fixed inset-0 bg-black/50 z-20 hidden lg:hidden"
        aria-hidden="true"
      ></div>

      <!-- Mobile sidebar panel -->
      <aside
        id="mobile-sidebar"
        class="fixed left-0 top-0 h-full overflow-y-auto z-30 border-r lg:hidden -translate-x-full transition-transform"
        style="
          width: var(--sidebar-width, 16rem);
          padding-top: var(--header-height, 3.5rem);
          background-color: var(--bg-sidebar);
          border-color: var(--border-color);
          transition-duration: var(--transition-duration, 0.2s);
        "
      >
        <Sidebar
          categories={sidebarCategories}
          activeCategorySlug={activeCategorySlug}
          activeArticleSlug={activeArticleSlug}
          locale={locale}
        />
      </aside>

      <!-- Main content -->
      <main
        class="flex-1 min-w-0 flex"
        style={`margin-left: 0;`}
      >
        <div
          class="flex-1 lg:ml-[var(--sidebar-width,16rem)] min-w-0"
        >
          <div
            class="flex justify-center"
            style="padding: var(--content-padding-y, 2rem) var(--content-padding-x, 1.5rem);"
          >
            <article
              class="flex-1 min-w-0"
              style="max-width: var(--max-content-width, 72rem);"
            >
              <slot />
            </article>

            <!-- TOC — desktop only -->
            {toc.length > 0 && (
              <aside
                class="hidden xl:block shrink-0 sticky"
                style="
                  width: var(--toc-width, 14rem);
                  top: calc(var(--header-height, 3.5rem) + 2rem);
                  height: fit-content;
                  margin-left: 2rem;
                "
              >
                <TableOfContents entries={toc} />
              </aside>
            )}
          </div>
        </div>
      </main>
    </div>

    <Footer settings={settings} style={`margin-left: var(--sidebar-width, 16rem);`} />
  </div>

  <!-- Mobile sidebar toggle script -->
  <script>
    const overlay = document.getElementById('sidebar-overlay');
    const mobileSidebar = document.getElementById('mobile-sidebar');
    const toggleBtn = document.getElementById('mobile-menu-btn');

    function openSidebar() {
      mobileSidebar?.classList.remove('-translate-x-full');
      overlay?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      mobileSidebar?.classList.add('-translate-x-full');
      overlay?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    toggleBtn?.addEventListener('click', openSidebar);
    overlay?.addEventListener('click', closeSidebar);

    // Close on route change (if using view transitions)
    document.addEventListener('astro:before-swap', closeSidebar);
  </script>
</BaseLayout>
